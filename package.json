{
  "name": "ochiel-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "build:web": "webpack --mode production",
    "start:web": "webpack serve --mode development",
    "backend:install": "cd backend && npm install",
    "backend:dev": "cd backend && npm run dev",
    "backend:init": "cd backend && npm run init-db",
    "backend:seed": "cd backend && npm run seed",
    "dev": "concurrently \"npm run backend:dev\" \"npm run start:web\"",
    "setup": "npm install && npm run backend:install && npm run backend:init && npm run backend:seed"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "buffer": "^6.0.3",
    "lucide-react-native": "^0.577.0",
    "process": "^0.11.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.73.6",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "~3.6.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.21.2",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-export-default-from": "^7.27.1",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.5",
    "@react-native/typescript-config": "0.73.1",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^2.1.1",
    "ajv-keywords": "^5.1.0",
    "babel-jest": "^29.6.3",
    "babel-loader": "^10.1.1",
    "babel-plugin-react-native-web": "^0.21.2",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.19.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "18.2.0",
    "typescript": "5.0.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "engines": {
    "node": ">=18"
  }
}